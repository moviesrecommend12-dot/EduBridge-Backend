# Orbiet / EduBridge local development environment

# Django
SECRET_KEY=replace-with-a-development-secret-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,testserver
CORS_ALLOW_ALL_ORIGINS=True
SERVE_STATIC_FILES=True

# MySQL
DB_ENGINE=django.db.backends.mysql
DB_NAME=orbiet_db
DB_USER=orbiet_user
DB_PASSWORD=Root123456
DB_HOST=127.0.0.1
DB_PORT=3306

# Stripe Test Mode
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
FRONTEND_SUCCESS_URL=http://127.0.0.1:8000/payment/success/
FRONTEND_CANCEL_URL=http://127.0.0.1:8000/payment/cancel/

# Firebase Cloud Messaging for Flutter push notifications
FCM_SERVER_KEY=replace-with-firebase-server-key
FCM_API_URL=https://fcm.googleapis.com/fcm/send
FCM_TIMEOUT_SECONDS=5

# Optional background queue for push sending
# Keep False for simple local runserver testing.
PUSH_NOTIFICATIONS_USE_CELERY=False
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=False

# Automatic reminder defaults
REMINDER_INVOICE_DAYS_BEFORE=3
REMINDER_ASSIGNMENT_DAYS_BEFORE=2
REMINDER_ABSENCE_WINDOW_DAYS=30
REMINDER_ABSENCE_THRESHOLD=3
REMINDERS_USE_CELERY_BEAT=False
REMINDERS_BEAT_HOUR=7
REMINDERS_BEAT_MINUTE=0
